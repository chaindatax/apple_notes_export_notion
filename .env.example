# Notion Integration Token
# Créer une intégration sur https://www.notion.so/my-integrations
# puis partager la base de données avec cette intégration
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID de la base de données Notion cible
# Visible dans l'URL de la database : notion.so/{workspace}/{DATABASE_ID}?v=...
NOTION_DATABASE_ID=3439ff0720c2807f8e1bddefbbec541d

# (Optionnel) Nom du dossier Apple Notes à exporter (défaut : B4B)
NOTES_FOLDER=B4B
